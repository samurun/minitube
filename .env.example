# Server
PORT=4000

# PostgreSQL
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=mydatabase
POSTGRES_HOST=db
POSTGRES_PORT=5432

# MinIO (S3-compatible)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_DATA_DIR=/data
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_USE_SSL=false

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASS=admin
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_HOST=rabbitmq

# Next.js (Web)
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Upload (optional — defaults shown)
# UPLOAD_MAX_SIZE_MB=1024
# CORS_ORIGINS=http://localhost:3000

# Worker (optional — defaults shown)
# WORKER_MAX_RETRIES=3
# FFMPEG_THREADS=1

# Thumbnail (optional — defaults shown)
# THUMBNAIL_TIMESTAMP_SEC=1
# THUMBNAIL_QUALITY=2

# Transcode / HLS (optional — defaults shown)
# TRANSCODE_FFMPEG_THREADS=2
# HLS_SEGMENT_DURATION=6
