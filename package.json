{
  "name": "minitube",
  "description": "A YouTube clone built with Next.js, Drizzle ORM, and PostgreSQL.",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:api": "turbo dev --filter=api",
    "dev:web": "turbo dev --filter=web",
    "dev:workers": "turbo dev --filter=worker-thumbnail --filter=worker-preview --filter=worker-transcode",
    "dev:all": "turbo dev --filter=api --filter=web --filter=worker-thumbnail --filter=worker-preview --filter=worker-transcode",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "db:push": "cd apps/api && bunx drizzle-kit push",
    "db:generate": "cd apps/api && bunx drizzle-kit generate",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:infra": "docker compose up -d db minio rabbitmq"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  }
}
